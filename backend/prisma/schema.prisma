generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Emotion {
  ANGRY
  ANXIOUS
  CALM
  FLUTTER
  HAPPY
  REFLECTIVE
  SAD
  TIRED
}

enum Visibility {
  PRIVATE
  ANONYMOUS
}

enum AuthProvider {
  KAKAO
  APPLE
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  nickname      String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  oauthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]
  records       Record[]

  @@map("users")
}

model OAuthAccount {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @default(uuid()) @map("family_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Place {
  id              String   @id @default(uuid()) @db.Uuid
  kakaoPlaceId    String   @unique @map("kakao_place_id")
  name            String
  categoryName    String?  @map("category_name")
  addressName     String   @map("address_name")
  roadAddressName String?  @map("road_address_name")
  latitude        Decimal  @db.Decimal(9, 6)
  longitude       Decimal  @db.Decimal(10, 6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  records         Record[]

  @@map("places")
}

model Record {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  placeId    String        @map("place_id") @db.Uuid
  title      String
  emotion    Emotion
  content    String?
  visibility Visibility    @default(PRIVATE)
  recordedAt DateTime      @map("recorded_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  place      Place         @relation(fields: [placeId], references: [id])
  images     RecordImage[]

  @@index([userId, recordedAt(sort: Desc)])
  @@index([placeId])
  @@index([emotion])
  @@map("records")
}

model RecordImage {
  id        String   @id @default(uuid()) @db.Uuid
  recordId  String   @map("record_id") @db.Uuid
  objectKey String   @unique @map("object_key")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  record    Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@unique([recordId, sortOrder])
  @@index([recordId])
  @@map("record_images")
}
